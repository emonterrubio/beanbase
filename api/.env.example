# ---------------------------------------------------------------------------
# Local development — copy to .env and fill in values
# ---------------------------------------------------------------------------

# Local Postgres
DATABASE_URL=postgresql://localhost:5432/beanbase

# Neon (production) — use the "direct" connection string (not pooled) for
# Alembic migrations. Pooled URL is fine for the running API.
# DATABASE_URL=postgresql://user:pass@ep-xxx-yyy.us-east-2.aws.neon.tech/neondb?sslmode=require

# Auth (Clerk)
CLERK_SECRET_KEY=

# Billing (Stripe)
STRIPE_SECRET_KEY=

STRIPE_WEBHOOK_SECRET=

# Observability
SENTRY_DSN=

# CORS — comma-separated list of allowed origins
# Production example: https://beanbase.vercel.app,https://www.beanbase.co
ALLOWED_ORIGINS=http://localhost:3000

ENVIRONMENT=development
